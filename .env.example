APP_NAME=The Abyss Auth API
ENV=development
DEBUG=true
SECRET_KEY=change-this-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/railway
FRONTEND_BASE_URL=http://localhost:5500

# Optional SMTP config for real verification email sending
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
