APP_NAME=The Abyss Auth API
ENV=development
DEBUG=true
SECRET_KEY=change-this-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/railway
FRONTEND_BASE_URL=http://localhost:5500
PUBLIC_API_BASE_URL=http://localhost:8000

# Email provider: auto | resend | smtp
EMAIL_PROVIDER=auto

# Resend (recommended on Railway because it uses HTTPS/443)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# SMTP fallback (works when outbound SMTP is allowed)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://theabyssauth.up.railway.app/auth/discord/callback
DISCORD_OAUTH_SCOPE=identify email
